{
  "name": "Karship",
  "scopeName": "source.karship",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.karship",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.karship",
          "match": "//.*$"
        },
        {
          "name": "comment.block.karship",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.karship",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.karship",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.karship",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.karship",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.karship",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.karship",
          "match": "\\b(let|lock|forge|if|elif|else|while|each|in|return|break|continue|use|spark|class|new|lambda|self)\\b"
        },
        {
          "name": "keyword.operator.logical.karship",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.karship",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.karship",
          "match": "\\bforge\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.karship"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.karship",
          "match": "==|!=|<=|>=|[+\\-*/%=<>]"
        }
      ]
    }
  }
}
